# MySQL (Docker: docker compose up -d)
DATABASE_URL="mysql://root:greenwood@localhost:3307/greenwood"

# Auth
JWT_SECRET="dev-secret-change-me"
JWT_EXPIRES_IN="7d"
OTP_TTL_MINUTES=5

# In dev, OTP codes are logged to the server console (no SMS sent).
# Set to a fixed value to make manual testing easy; leave empty for random codes.
DEV_FIXED_OTP="123456"

# Server
PORT=4000
CORS_ORIGIN="http://localhost:5173"
NODE_ENV="development"
