# MySQL (Docker: docker compose up -d)
DATABASE_URL="mysql://root:greenwood@localhost:3307/greenwood"

# Auth
JWT_SECRET="dev-secret-change-me"
JWT_EXPIRES_IN="7d"
OTP_TTL_MINUTES=5

# In dev, OTP codes are logged to the server console (no SMS sent).
# Set to a fixed value to make manual testing easy; leave empty for random codes.
DEV_FIXED_OTP="123456"

# Server
PORT=4000
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:5173,https://superadmin.shopyoume.in"
NODE_ENV="development"

# S3 (school logo uploads). Leave AWS_S3_BUCKET empty to disable uploads.
AWS_REGION="ap-south-1"
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Folder/prefix logos are stored under.
AWS_S3_PREFIX="school-logos"
# Optional: CloudFront/custom domain for reading logos. Leave empty to use the
# default https://<bucket>.s3.<region>.amazonaws.com URL.
AWS_S3_PUBLIC_BASE_URL=""
